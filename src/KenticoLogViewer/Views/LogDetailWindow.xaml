<Window x:Class="KenticoLogViewer.Views.LogDetailWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Event details"
        Width="800" Height="600"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResizeWithGrip">

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Error banner -->
        <Border Grid.Row="0" Background="#FFEBEE" Padding="8,6" Margin="0,0,0,8">
            <Border.Style>
                <Style TargetType="Border">
                    <Setter Property="Visibility" Value="Collapsed"/>
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding HasError}" Value="True">
                            <Setter Property="Visibility" Value="Visible"/>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </Border.Style>
            <TextBlock Text="{Binding ErrorMessage}" Foreground="#C62828" FontWeight="SemiBold" TextWrapping="Wrap"/>
        </Border>

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <ItemsControl ItemsSource="{Binding Fields}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border BorderBrush="#E0E0E0" BorderThickness="0,0,0,1" Padding="4,6">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="180"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="{Binding Label}"
                                           FontWeight="SemiBold" VerticalAlignment="Top"/>
                                <TextBox Grid.Column="1" Text="{Binding Value}"
                                         IsReadOnly="True" TextWrapping="Wrap"
                                         BorderThickness="0" Background="Transparent"
                                         VerticalScrollBarVisibility="Auto"
                                         MaxHeight="120"/>
                                <Button Grid.Column="2" Content="📋"
                                    ToolTip="Copy"
                                        Margin="4,0,0,0"
                                        VerticalAlignment="Top"
                                        Command="{Binding DataContext.CopyFieldCommand,
                                                  RelativeSource={RelativeSource AncestorType=Window}}"
                                        CommandParameter="{Binding Value}"/>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>

        <Button Grid.Row="2" Content="Close"
            HorizontalAlignment="Right" Margin="0,12,0,0"
            Padding="16,6" IsCancel="True"/>
    </Grid>
</Window>
