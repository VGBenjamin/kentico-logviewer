
<Window x:Class="KenticoLogViewer.Views.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:views="clr-namespace:KenticoLogViewer.Views"
    xmlns:conv="clr-namespace:KenticoLogViewer.Converters"
    Title="Kentico Log Viewer"
    Width="1280" Height="760"
    WindowStartupLocation="CenterScreen"
    Icon="pack://application:,,,/Properties/icon.ico">

    <Window.Resources>
        <conv:EventTypeToColorConverter x:Key="EventTypeColor"/>
        <conv:TruncateTextConverter x:Key="TruncateText" MaxLength="200"/>

        <!-- DataGrid row coloring by EventType -->
        <Style x:Key="EventLogRowStyle" TargetType="DataGridRow">
            <Style.Triggers>
                <DataTrigger Binding="{Binding EventType}" Value="E">
                    <Setter Property="Background" Value="#FFEBEE"/>
                </DataTrigger>
                <DataTrigger Binding="{Binding EventType}" Value="W">
                    <Setter Property="Background" Value="#FFF8E1"/>
                </DataTrigger>
                <DataTrigger Binding="{Binding EventType}" Value="I">
                    <Setter Property="Background" Value="White"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Toolbar -->
        <ToolBar Grid.Row="0" Padding="4,4">
            <!-- Connection selector -->
            <Label Content="Connection:" VerticalAlignment="Center"/>
            <ComboBox ItemsSource="{Binding Connections}"
                      SelectedItem="{Binding SelectedConnection}"
                      DisplayMemberPath="Name"
                      Width="200" Margin="0,0,4,0"/>
            <Button Content="Manage…" Click="OnManageConnectionsClick" Padding="8,4" Margin="0,0,8,0"/>

            <Separator/>

            <Button Content="⟳ Refresh" Command="{Binding RefreshCommand}" Padding="8,4" Margin="0,0,4,0"/>
            <Button Content="Advanced filters" Command="{Binding ToggleAdvancedFiltersCommand}" Padding="8,4" Margin="0,0,8,0"/>
            <Button Content="Reset filters" Command="{Binding ResetFiltersCommand}" Padding="8,4" Margin="0,0,8,0"/>

            <Separator/>

            <!-- Auto-refresh -->
            <CheckBox Content="Auto-refresh" IsChecked="{Binding AutoRefreshEnabled}" VerticalAlignment="Center" Margin="0,0,6,0"/>
            <ComboBox ItemsSource="{Binding RefreshIntervals}"
                      SelectedItem="{Binding AutoRefreshInterval}"
                      Width="60" Margin="0,0,4,0">
                <ComboBox.Style>
                    <Style TargetType="ComboBox">
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding AutoRefreshEnabled}" Value="False">
                                <Setter Property="Visibility" Value="Collapsed"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </ComboBox.Style>
                <ComboBox.ItemTemplate>
                    <DataTemplate>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="{Binding}"/>
                            <TextBlock Text="s"/>
                        </StackPanel>
                    </DataTemplate>
                </ComboBox.ItemTemplate>
            </ComboBox>

            <Separator/>

            <Button Content="📋 Copy selection" Command="{Binding CopySelectedCommand}" Padding="8,4"/>

            <!-- Loading indicator -->
            <ProgressBar IsIndeterminate="True" Width="80" Height="14" Margin="12,0,0,0">
                <ProgressBar.Style>
                    <Style TargetType="ProgressBar">
                        <Setter Property="Visibility" Value="Collapsed"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsLoading}" Value="True">
                                <Setter Property="Visibility" Value="Visible"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </ProgressBar.Style>
            </ProgressBar>
        </ToolBar>

        <!-- Error banner -->
        <Border Grid.Row="1" Background="#FFEBEE" Padding="10,6">
            <Border.Style>
                <Style TargetType="Border">
                    <Setter Property="Visibility" Value="Collapsed"/>
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding HasError}" Value="True">
                            <Setter Property="Visibility" Value="Visible"/>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </Border.Style>
            <TextBlock Text="{Binding ErrorMessage}" Foreground="#C62828"
                       FontWeight="SemiBold" TextWrapping="Wrap"/>
        </Border>

        <!-- Main content: DataGrid + optional advanced filter panel -->
        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <!-- DataGrid -->
            <DataGrid Grid.Column="0"
                      x:Name="LogGrid"
                      ItemsSource="{Binding Logs}"
                      AutoGenerateColumns="False"
                      IsReadOnly="True"
                      CanUserSortColumns="True"
                      SelectionMode="Extended"
                      VirtualizingPanel.IsVirtualizing="True"
                      VirtualizingPanel.VirtualizationMode="Recycling"
                      EnableRowVirtualization="True"
                      RowStyle="{StaticResource EventLogRowStyle}"
                      MouseDoubleClick="OnGridDoubleClick"
                      SelectionChanged="OnGridSelectionChanged"
                      GridLinesVisibility="Horizontal"
                      BorderThickness="0">

                <DataGrid.Columns>
                    <!-- EventID with min-filter -->
                    <DataGridTextColumn Binding="{Binding EventID}" Width="90"
                                        SortMemberPath="EventID">
                        <DataGridTextColumn.HeaderTemplate>
                            <DataTemplate>
                                <StackPanel>
                                    <TextBlock Text="EventID" FontWeight="SemiBold" Margin="0,0,0,2"/>
                                    <TextBox Text="{Binding DataContext.Filter.EventIdMinFilter,
                                                     RelativeSource={RelativeSource AncestorType=DataGrid},
                                                     UpdateSourceTrigger=PropertyChanged}"
                                             ToolTip="Filtre EventID min" MinWidth="70"/>
                                </StackPanel>
                            </DataTemplate>
                        </DataGridTextColumn.HeaderTemplate>
                    </DataGridTextColumn>

                    <!-- EventType with E/W/I checkboxes -->
                    <DataGridTextColumn Binding="{Binding EventType}" Width="75"
                                        SortMemberPath="EventType">
                        <DataGridTextColumn.HeaderTemplate>
                            <DataTemplate>
                                <StackPanel>
                                    <TextBlock Text="Type" FontWeight="SemiBold" Margin="0,0,0,2"/>
                                    <CheckBox Content="E"
                                              IsChecked="{Binding DataContext.Filter.FilterTypeE,
                                                           RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                              Foreground="#C62828"/>
                                    <CheckBox Content="W"
                                              IsChecked="{Binding DataContext.Filter.FilterTypeW,
                                                           RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                              Foreground="#E65100"/>
                                    <CheckBox Content="I"
                                              IsChecked="{Binding DataContext.Filter.FilterTypeI,
                                                           RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                              Foreground="#1565C0"/>
                                </StackPanel>
                            </DataTemplate>
                        </DataGridTextColumn.HeaderTemplate>
                    </DataGridTextColumn>

                    <!-- DateFrom / DateTo -->
                    <DataGridTextColumn Binding="{Binding EventTime, StringFormat='yyyy-MM-dd HH:mm:ss'}"
                                        Width="160" SortMemberPath="EventTime">
                        <DataGridTextColumn.HeaderTemplate>
                            <DataTemplate>
                                <StackPanel>
                                    <TextBlock Text="Date/Time" FontWeight="SemiBold" Margin="0,0,0,2"/>
                                    <DatePicker SelectedDate="{Binding DataContext.Filter.DateFrom,
                                                                RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                                ToolTip="Start Date" Width="148"/>
                                    <TextBox Text="{Binding DataContext.Filter.DateFromTimeStr,
                                                     RelativeSource={RelativeSource AncestorType=DataGrid},
                                                     UpdateSourceTrigger=PropertyChanged}"
                                             ToolTip="Start Time (HH:mm:ss)" Width="148" Margin="0,2,0,2"/>
                                    <DatePicker SelectedDate="{Binding DataContext.Filter.DateTo,
                                                                RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                                ToolTip="End Date" Width="148" Margin="0,2,0,0"/>
                                    <TextBox Text="{Binding DataContext.Filter.DateToTimeStr,
                                                     RelativeSource={RelativeSource AncestorType=DataGrid},
                                                     UpdateSourceTrigger=PropertyChanged}"
                                             ToolTip="End Time (HH:mm:ss)" Width="148" Margin="0,2,0,0"/>
                                </StackPanel>
                            </DataTemplate>
                        </DataGridTextColumn.HeaderTemplate>
                    </DataGridTextColumn>

                    <!-- Source -->
                    <DataGridTextColumn Binding="{Binding Source}" Width="140"
                                        SortMemberPath="Source">
                        <DataGridTextColumn.HeaderTemplate>
                            <DataTemplate>
                                <StackPanel>
                                    <TextBlock Text="Source" FontWeight="SemiBold" Margin="0,0,0,2"/>
                                    <TextBox Text="{Binding DataContext.Filter.SourceFilter,
                                                     RelativeSource={RelativeSource AncestorType=DataGrid},
                                                     UpdateSourceTrigger=PropertyChanged}"
                                             MinWidth="110"/>
                                </StackPanel>
                            </DataTemplate>
                        </DataGridTextColumn.HeaderTemplate>
                    </DataGridTextColumn>

                    <!-- EventCode -->
                    <DataGridTextColumn Binding="{Binding EventCode}" Width="120"
                                        SortMemberPath="EventCode">
                        <DataGridTextColumn.HeaderTemplate>
                            <DataTemplate>
                                <StackPanel>
                                    <TextBlock Text="Code" FontWeight="SemiBold" Margin="0,0,0,2"/>
                                    <TextBox Text="{Binding DataContext.Filter.EventCodeFilter,
                                                     RelativeSource={RelativeSource AncestorType=DataGrid},
                                                     UpdateSourceTrigger=PropertyChanged}"
                                             MinWidth="90"/>
                                </StackPanel>
                            </DataTemplate>
                        </DataGridTextColumn.HeaderTemplate>
                    </DataGridTextColumn>

                    <!-- Description -->
                    <DataGridTemplateColumn Width="*" SortMemberPath="EventDescription">
                        <DataGridTemplateColumn.HeaderTemplate>
                            <DataTemplate>
                                <StackPanel>
                                    <TextBlock Text="Description" FontWeight="SemiBold" Margin="0,0,0,2"/>
                                    <TextBox Text="{Binding DataContext.Filter.EventDescriptionFilter,
                                                     RelativeSource={RelativeSource AncestorType=DataGrid},
                                                     UpdateSourceTrigger=PropertyChanged}"
                                             MinWidth="120"/>
                                </StackPanel>
                            </DataTemplate>
                        </DataGridTemplateColumn.HeaderTemplate>
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding EventDescription, Converter={StaticResource TruncateText}}"
                                           TextTrimming="CharacterEllipsis"
                                           ToolTip="{Binding EventDescription}"
                                           Padding="2"/>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                </DataGrid.Columns>
            </DataGrid>

            <!-- Advanced filter panel (collapsible) -->
            <Border Grid.Column="1" Width="260"
                    BorderBrush="#BDBDBD" BorderThickness="1,0,0,0"
                    Background="#FAFAFA">
                <Border.Style>
                    <Style TargetType="Border">
                        <Setter Property="Visibility" Value="Collapsed"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding ShowAdvancedFilters}" Value="True">
                                <Setter Property="Visibility" Value="Visible"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Border.Style>
                <views:FilterPanelControl DataContext="{Binding Filter}"/>
            </Border>
        </Grid>

        <!-- Status bar -->
        <StatusBar Grid.Row="3">
            <StatusBarItem>
                <TextBlock Text="{Binding StatusMessage}"/>
            </StatusBarItem>
            <Separator/>
            <StatusBarItem>
                <TextBlock Text="{Binding LastRefresh}"/>
            </StatusBarItem>
        </StatusBar>
    </Grid>
</Window>
